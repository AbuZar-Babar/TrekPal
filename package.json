{
  "name": "trekpal-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "TrekPal - Travel Management Ecosystem Monorepo",
  "author": "Hashim and Ali",
  "license": "ISC",
  "workspaces": [
    "backend",
    "admin-portal",
    "agency-portal",
    "hotel-portal",
    "vehicle-portal"
  ],
  "scripts": {
    "preinstall": "echo 🎬 Installing TrekPal workspace dependencies...",
    "postinstall": "echo ✅ Workspace installation complete!",

    "dev": "concurrently -n admin,agency,hotel,vehicle -c blue,green,magenta,yellow \"npm:dev:admin\" \"npm:dev:agency\" \"npm:dev:hotel\" \"npm:dev:vehicle\" --kill-others",
    "dev:all": "concurrently -n backend,admin,agency,hotel,vehicle -c cyan,blue,green,magenta,yellow \"npm:dev:backend\" \"npm:dev:admin\" \"npm:dev:agency\" \"npm:dev:hotel\" \"npm:dev:vehicle\" --kill-others",
    "dev:with-backend": "npm run dev:all",

    "dev:backend": "npm run dev --workspace=backend",
    "dev:admin": "npm run dev --workspace=admin-portal",
    "dev:agency": "npm run dev --workspace=agency-portal",
    "dev:hotel": "npm run dev --workspace=hotel-portal",
    "dev:vehicle": "npm run dev --workspace=vehicle-portal",

    "dev:web": "concurrently -n admin,agency,hotel,vehicle -c blue,green,magenta,yellow \"npm:dev:admin\" \"npm:dev:agency\" \"npm:dev:hotel\" \"npm:dev:vehicle\" --kill-others",
    "dev:backend-only": "npm run dev --workspace=backend",
    "dev:admin-only": "npm run dev --workspace=admin-portal",
    "dev:agency-only": "npm run dev --workspace=agency-portal",
    "dev:hotel-only": "npm run dev --workspace=hotel-portal",
    "dev:vehicle-only": "npm run dev --workspace=vehicle-portal",

    "build": "npm run build --workspaces --if-present",
    "build:backend": "npm run build --workspace=backend",
    "build:admin": "npm run build --workspace=admin-portal",
    "build:agency": "npm run build --workspace=agency-portal",
    "build:hotel": "npm run build --workspace=hotel-portal",
    "build:vehicle": "npm run build --workspace=vehicle-portal",

    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint:fix --workspaces --if-present",

    "prisma:generate": "npm run prisma:generate --workspace=backend",
    "prisma:migrate": "npm run prisma:migrate --workspace=backend",
    "prisma:migrate:deploy": "npm run prisma:migrate:deploy --workspace=backend",
    "prisma:studio": "npm run prisma:studio --workspace=backend",
    "seed": "npm run seed --workspace=backend",
    "db:counts": "npm run db:counts --workspace=backend",
    "migrate:kyc": "npm run migrate:kyc --workspace=backend",
    "migrate:kyc:execute": "npm run migrate:kyc:execute --workspace=backend",
    "storage:kyc:ensure": "npm run storage:kyc:ensure --workspace=backend",

    "db:setup": "echo 🗄️ Setting up database... && npm run prisma:generate && npm run prisma:migrate && npm run seed && echo ✅ Database setup complete!",
    "db:studio": "npm run prisma:studio",
    "db:reset": "npm run prisma:migrate -- reset && npm run seed",

    "clean": "npm run clean:modules && npm run clean:builds",
    "clean:modules": "rimraf node_modules backend/node_modules admin-portal/node_modules agency-portal/node_modules hotel-portal/node_modules vehicle-portal/node_modules",
    "clean:builds": "rimraf backend/dist admin-portal/dist agency-portal/dist hotel-portal/dist vehicle-portal/dist",

    "postinstall:all": "npm install && npm run prisma:generate"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "rimraf": "^5.0.5"
  },
  "engines": {
    "node": "20.x",
    "npm": ">=10.0.0"
  }
}
